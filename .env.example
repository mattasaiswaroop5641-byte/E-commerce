# Flask Configuration
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=your-secret-key-here-change-in-production

# Database
DATABASE_URL=sqlite:///ecommerce.db

# Email (required for signup/login/order emails)
# Option A (Recommended): Resend
# - Create an API key at https://resend.com
# - In production, use a verified sender/domain for `MAIL_FROM_ADDRESS`.
RESEND_API_KEY=
MAIL_FROM_NAME=ShadowMarket
MAIL_FROM_ADDRESS=onboarding@resend.dev

# Option B: SMTP (fallback if RESEND_API_KEY is not set)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_USE_TLS=true
MAIL_SEND_LOGIN_NOTIFICATIONS=true

# Stripe (required for real card payments)
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_CURRENCY=usd

# Admin Panel (professional admin console + 2FA)
# Admin URL: /admin/login
ADMIN_ENABLED=true
ADMIN_EMAIL=admin@example.com
# Recommended: store a hash, not plain text.
# Generate: python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('ChangeMe'))"
ADMIN_PASSWORD_HASH=
# Development fallback (not recommended for production):
ADMIN_PASSWORD=
# TOTP secret for Google Authenticator / Authy.
# Generate (no deps): python -c "import base64,secrets; print(base64.b32encode(secrets.token_bytes(20)).decode().replace('=',''))"
ADMIN_TOTP_SECRET=
ADMIN_REQUIRE_2FA=true

# Render Deployment
# On Render, set SECRET_KEY to a strong random string
